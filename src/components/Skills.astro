---
import { skills } from '../data/skills';
---
<section id="skills" class="max-w-6xl mx-auto px-6 py-24 scroll-mt-20">
  <h2 class="font-mono text-sm text-[var(--primary)] tracking-widest uppercase mb-10 reveal">
    02 / Skills
  </h2>
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {skills.map((group, i) => (
      <div class="glass-card p-6 reveal" style={`transition-delay:${i * 60}ms`}>
        <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--text-dim)] mb-4">
          {group.category}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.items.map((it) => <li class="chip">{it}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>
