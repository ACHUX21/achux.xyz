---
import Icon from './Icon.astro';
import { projects } from '../data/projects';
---
<section id="projects" class="max-w-6xl mx-auto px-6 py-24 scroll-mt-20">
  <h2 class="font-mono text-sm text-[var(--primary)] tracking-widest uppercase mb-10 reveal">
    03 / Projects
  </h2>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((p, i) => (
      <article class="glass-card p-6 flex flex-col reveal" style={`transition-delay:${i * 50}ms`}>
        <div class="flex items-start justify-between gap-3 mb-1">
          <h3 class="text-xl font-semibold">{p.name}</h3>
          {p.private && (
            <span class="chip !text-[0.65rem] shrink-0" title="Private repository">
              <Icon name="lock" size={12} class="mr-1" /> private
            </span>
          )}
        </div>
        <p class="font-mono text-xs text-[var(--primary)] mb-3">{p.tagline}</p>
        <p class="text-sm text-[var(--text-dim)] leading-relaxed mb-5 grow">{p.description}</p>
        <ul class="flex flex-wrap gap-1.5 mb-5">
          {p.tags.map((t) => <li class="chip !text-[0.65rem]">{t}</li>)}
        </ul>
        <div class="flex items-center gap-4 text-sm mt-auto">
          {p.repo && (
            <a href={p.repo} target="_blank" rel="noopener noreferrer" class="link-underline inline-flex items-center gap-1.5">
              <Icon name="github" size={16} /> Code
            </a>
          )}
          {p.live && (
            <a href={p.live} target="_blank" rel="noopener noreferrer" class="link-underline inline-flex items-center gap-1.5">
              <Icon name="external" size={16} /> Live
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
