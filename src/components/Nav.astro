---
import Icon from './Icon.astro';
import { socials } from '../data/site';

const links = [
  { label: 'About', href: '#about' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'CTF', href: '#ctf' },
  { label: 'Contact', href: '#contact' },
];
const navSocials = socials.filter((s) => ['github', 'linkedin', 'ctftime'].includes(s.icon));
---
<header class="fixed top-0 inset-x-0 z-50">
  <nav
    class="mx-auto max-w-6xl mt-3 px-4 sm:px-6 py-3 flex items-center justify-between glass-card !rounded-full"
  >
    <a href="#top" class="font-mono font-bold tracking-tight text-lg">
      <span class="grad-text">ACHUX21</span>
    </a>

    <ul class="hidden md:flex items-center gap-6 text-sm">
      {links.map((l) => (
        <li><a href={l.href} class="link-underline">{l.label}</a></li>
      ))}
    </ul>

    <div class="flex items-center gap-1.5">
      <a
        href="https://blog.achux.xyz"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost !py-1.5 !px-3 !text-xs mr-1"
      >
        Blog
      </a>
      {navSocials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="p-2 rounded-full hover:text-[var(--primary)] transition-colors"
        >
          <Icon name={s.icon} size={18} />
        </a>
      ))}
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="p-2 rounded-full hover:text-[var(--primary)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36A5.4 5.4 0 0 1 12 3Z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>
